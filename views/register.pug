extends layout

block content
  .row.justify-content-center
    .col-md-6
      .card.shadow-lg.border-0
        .card-header.bg-dark.text-white.text-center.py-3
          h4.mb-0  Staff Registration
          small.text-warning Nyondo General Hardware LTD

        .card-body.p-4
          form(action="/users/register" method="POST")
            //- Full Name
            .mb-3
              label.form-label Full Name
              input.form-control(type="text" name="fullname" placeholder="Enter full name" required)

            .row
              //- Phone Number (Validation: Ugandan Format)
              .col-md-6.mb-3
                label.form-label Phone Number
                input.form-control(type="tel" name="phone" pattern="[0-9]{10}" placeholder="07XXXXXXXX" title="Please enter a 10-digit Ugandan number" required)
              
              //- NIN (Validation: Ugandan Format 14 characters)
              .col-md-6.mb-3
                label.form-label NIN
                input.form-control(type="text" name="nin" minlength="14" maxlength="14" placeholder="14 Character NIN" required)

            //- Role Selection 
            .mb-3
              label.form-label Assign Role
              select.form-select(name="role" required)
                option(value="" disabled selected) -- Select Staff Role --
                option(value="Sales Attendant") Sales Attendant
                option(value="Store Manager") Store Manager
                option(value="Accounts/Admin") Accounts/Admin

            hr.my-4

            //- Account Credentials
            .mb-3
              label.form-label Email Address
              input.form-control(type="email" name="email" placeholder="staff@nyondo.com" required)
            
            .mb-4
              label.form-label Password
              input.form-control(type="password" name="password" placeholder="Create secure password" required)

            .d-grid
              button.btn.btn-primary.btn-lg(type="submit") Create Staff Account

        .card-footer.text-center.py-3
          a.text-muted.small(href="/dashboard") Back to Dashboard