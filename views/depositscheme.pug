extends layout

block content
  .container-fluid
    .row.mb-4.align-items-center
      .col-md-8
        h2.text-cyan.fw-bold Deposit Scheme Management
        p.text-white-50 Record customer savings for hardware materials.
      .col-md-4.text-end
        a.btn-cyan(href="/dashboard" style="text-decoration: none; font-size: 0.8rem;") ← BACK TO DASHBOARD

    if error
      .error-msg.mb-4 #{error}

    .row.g-4
      //- Deposit Entry Form
      .col-lg-4
        .glass-card
          h5.text-cyan.mb-4 Record New Transaction
          form(action="/deposits/add" method="post")
            .mb-3
              label.text-white-50.small Acting Staff Role
              select.form-control(name="staffRole" required)
                option(value="Sales Attendant") Sales Attendant
                option(value="Store Manager") Store Manager
                option(value="Accounts/Admin") Accounts/Admin
            
            hr(style="border-color: var(--border-color)")
            
            .mb-2
              label.text-white-50.small Customer Name
              input.form-control(name="customerName" required)
            .mb-2
              label.text-white-50.small Phone Number
              input.form-control(name="phone" pattern="[0-9]{10}" placeholder="07XXXXXXXX" required)
            .mb-2
              label.text-white-50.small NIN
              input.form-control(name="nin" minlength="14" maxlength="14" required)
            .mb-3
              label.text-white-50.small Amount to Deposit (UGX)
              input.form-control.blue-input(type="number" name="amount" min="1000" required)
            
            button.btn-cyan.w-100(type="submit") SUBMIT DEPOSIT

      //- Ledger Table
      .col-lg-8
        .glass-card
          h5.text-cyan.mb-4 Recent Deposits Ledger
          .table-responsive
            table.nyondo-table
              thead
                tr
                  th Customer
                  th Contact/NIN
                  th.text-end Balance (UGX)
                  th.text-center Date
              tbody
                if accounts.length > 0
                  each acc in accounts
                    tr
                      td: .fw-bold.text-white= acc.customerName
                      td
                        small.d-block.text-white-50= acc.phone
                        small.text-cyan(style="font-size: 0.7rem;") NIN: #{acc.nin}
                      td.text-end.fw-bold(style="color: var(--success-green)")= acc.amount.toLocaleString()
                      td.text-center.small.text-white-50= acc.date.toLocaleDateString()
                else
                  tr
                    td.text-center.py-4(colspan="4") No deposit records found in database.