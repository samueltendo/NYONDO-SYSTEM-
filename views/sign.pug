doctype html
html
  head
    title NyondoStock | #{title}
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    style.
      body { background: #f4f7f6; height: 100vh; display: flex; align-items: center; }
      .login-card { max-width: 400px; width: 100%; margin: auto; border: none; border-radius: 15px; }
      .btn-nyondo { background: #1a1a1a; color: white; transition: 0.3s; }
      .btn-nyondo:hover { background: #333; color: #ffc107; }

  body
    .container
      .card.login-card.shadow-lg
        .card-body.p-5
          .text-center.mb-4
            h2.fw-bold NyondoStock
            p.text-muted Staff Portal Login
          
          if error
            .alert.alert-danger.small.text-center= error

          form(action="/auth/login" method="post")
            .mb-3
              label.form-label Email Address
              input.form-control(type="email" name="email" placeholder="name@nyondo.com" required)
            
            .mb-4
              label.form-label Password
              input.form-control(type="password" name="password" placeholder="••••••••" required)
            
            .d-grid
              button.btn.btn-nyondo.btn-lg(type="submit") Sign In

          .mt-4.text-center
            small.text-muted Nyondo General Hardware LTD &copy; 2026