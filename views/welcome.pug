doctype html
html
  head
    title NyondoStock | Welcome
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="/css/style.css")
  body(style="display: flex; justify-content: center; align-items: center; height: 100vh; text-align: center; background: radial-gradient(circle at top, #0b1a33, #010816);")
    .container
      .glass-card.py-5(style="max-width: 800px; margin: auto;")
        h1.display-3.text-cyan.fw-bold NYONDO STOCK
        p.lead.text-white.mb-4 Professional Inventory & Sales Management for Nyondo General Hardware.
        
        .row.g-4.mb-5.text-start
          .col-md-4
            .notification-item
              h6  Smart Stock
              small Track cement, steel, and hardware in real-time.
          .col-md-4
            .notification-item
              h6  Auto-Transport
              small Automated UGX 3,000/KM delivery calculations.
          .col-md-4
            .notification-item
              h6  Role Control
              small Secure access for Managers and Attendants.

        //- THIS LINK TAKES THEM TO THE LOGIN PAGE
        a.btn-cyan.btn-lg(href="/auth/login") ENTER SYSTEM TERMINAL
        
        .mt-5
          p.text-white-50.small &copy; 2026 Nyondo General Hardware LTD.