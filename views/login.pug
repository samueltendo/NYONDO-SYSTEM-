doctype html
html
  head
    title NyondoStock | #{title}
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="/css/style.css")
  body(style="display: flex; justify-content: center; align-items: center; height: 100vh;")
    .container(style="max-width: 450px;")
      .glass-card.text-center
        h2.text-cyan NYONDO STOCK
        p.text-white-50.mb-4 Staff Authentication Terminal
        
        if error
          .error-msg.mb-3 #{error}

        form(action="/auth/login" method="POST")
          .form-group.text-start.mb-3
            label.text-white-50 Email Address
            input.form-control(type="email" name="email" placeholder="staff@nyondo.com" required)
          
          .form-group.text-start.mb-4
            label.text-white-50 Password
            input.form-control(type="password" name="password" placeholder="••••••••" required)
          
          button.btn-cyan(type="submit" style="width: 100%;") ACCESS SYSTEM
        
        .mt-4
          small.text-muted © 2024 Nyondo General Hardware